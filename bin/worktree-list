#!/bin/bash
# List git worktrees / jj workspaces as JSON array
# Output: [{"type":"git|jj","description":"<branch|workspace-name>","path":"<path>"}]

set -euo pipefail

entries="[]"
jj_paths=""

add_entry() {
    entries="$(echo "$entries" | jq --arg type "$1" --arg desc "$2" --arg path "$3" \
        '. + [{"type": $type, "description": $desc, "path": $path}]')"
}

# jj workspaces
if jj workspace root > /dev/null 2>&1; then
    while IFS= read -r ws_name; do
        ws_path="$(jj workspace root --name "$ws_name" 2>/dev/null)" || continue
        jj_paths="${jj_paths}${ws_path}"$'\n'
        add_entry "jj" "$ws_name" "$ws_path"
    done < <(jj workspace list --template 'name ++ "\n"')
fi

# git worktrees (skip paths already covered by jj)
if git rev-parse --git-dir > /dev/null 2>&1; then
    current_path=""
    current_branch=""
    while IFS= read -r line; do
        if [[ "$line" =~ ^worktree\ (.+) ]]; then
            current_path="${BASH_REMATCH[1]}"
            current_branch=""
        elif [[ "$line" == "detached" ]]; then
            current_branch="(detached)"
        elif [[ "$line" =~ ^branch\ refs/heads/(.+) ]]; then
            current_branch="${BASH_REMATCH[1]}"
        elif [[ -z "$line" && -n "$current_path" ]]; then
            if ! echo "$jj_paths" | grep -qxF "$current_path"; then
                add_entry "git" "$current_branch" "$current_path"
            fi
            current_path=""
            current_branch=""
        fi
    done < <(git worktree list --porcelain; echo "")
fi

if [[ "$(echo "$entries" | jq 'length')" -eq 0 ]]; then
    echo "Error: Not in a git or jj repository" >&2
    exit 1
fi

echo "$entries"
